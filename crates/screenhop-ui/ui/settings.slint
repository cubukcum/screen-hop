import { Theme } from "theme.slint";
import { StrokeIcon } from "icons.slint";

// Approximate 24×24 glyphs (lines/beziers only — no arcs — for renderer portability).
export global Ico {
    out property <string> gear: "M9 9 L15 9 L15 15 L9 15 Z M12 5.5 L12 9 M12 15 L12 18.5 M5.5 12 L9 12 M15 12 L18.5 12 M7.5 7.5 L9.5 9.5 M14.5 14.5 L16.5 16.5 M7.5 16.5 L9.5 14.5 M14.5 9.5 L16.5 7.5";
    out property <string> link: "M9.7 14.3 L14.3 9.7 M8 11 L6.3 12.7 C5 14 5 16 6.3 17.3 C7.6 18.6 9.6 18.6 11 17.3 L12.5 15.8 M11.5 8.2 L13 6.7 C14.4 5.4 16.4 5.4 17.7 6.7 C19 8 19 10 17.7 11.3 L16 13";
    out property <string> net: "M3 8.5 C7 4.5 17 4.5 21 8.5 M5.5 11.8 C9 8.5 15 8.5 18.5 11.8 M8.6 15 C10.5 13 13.5 13 15.4 15";
    out property <string> refresh: "M20 5 L20 9.5 L15.5 9.5 M20 9.5 C18 4.5 11.5 3 7 6.5 C2.5 10 2.5 16.5 7 20";
    out property <string> power: "M12 3.5 L12 10.5 M7.4 7.3 C4.7 9.6 4.7 15 8.6 17.4 C12.6 19.9 17.6 17.8 18 12.6 C18.2 10.2 17 8.2 16.2 7.4";
    out property <string> sun: "M12 8.5 C14 8.5 15.5 10 15.5 12 C15.5 14 14 15.5 12 15.5 C10 15.5 8.5 14 8.5 12 C8.5 10 10 8.5 12 8.5 M12 3.5 L12 5.5 M12 18.5 L12 20.5 M3.5 12 L5.5 12 M18.5 12 L20.5 12 M6 6 L7.5 7.5 M16.5 16.5 L18 18 M6 18 L7.5 16.5 M16.5 7.5 L18 6";
    out property <string> keyboard: "M3 7 L21 7 L21 17 L3 17 Z M8 13.7 L16 13.7";
    out property <string> info: "M5 12 C5 8 8 5 12 5 C16 5 19 8 19 12 C19 16 16 19 12 19 C8 19 5 16 5 12 M12 11 L12 16 M12 7.6 L12 7.7";
}

component Toggle inherits Rectangle {
    in property <bool> on;
    width: 40px;
    height: 21px;
    border-radius: 11px;
    background: on ? Theme.accent : Theme.subtle;
    border-width: on ? 0px : 1px;
    border-color: Theme.ctl-stroke;
    Rectangle {
        width: 15px;
        height: 15px;
        border-radius: 8px;
        background: #ffffff;
        x: on ? parent.width - self.width - 3px : 3px;
        y: 3px;
    }
}

component Seg3 inherits Rectangle {
    in property <int> active;
    height: 26px;
    width: 174px;
    border-radius: 7px;
    border-width: 1px;
    border-color: Theme.ctl-stroke;
    background: Theme.subtle;
    HorizontalLayout {
        padding: 2px;
        spacing: 2px;
        for o[i] in ["System", "Light", "Dark"]: Rectangle {
            horizontal-stretch: 1;
            border-radius: 6px;
            background: i == active ? Theme.accent : transparent;
            Text { text: o; color: i == active ? #ffffff : Theme.text2; font-size: 12px; font-weight: 600; horizontal-alignment: center; vertical-alignment: center; }
        }
    }
}

component NavItem inherits Rectangle {
    in property <string> label;
    in property <string> icon;
    in property <bool> active;
    height: 34px;
    border-radius: 6px;
    background: active ? Theme.accent-soft : transparent;
    if active : Rectangle { x: 0; y: 8px; width: 3px; height: 18px; border-radius: 2px; background: Theme.accent; }
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 9px;
        VerticalLayout { alignment: center; StrokeIcon { width: 16px; height: 16px; tint: active ? Theme.accent-text : Theme.text2; commands: root.icon; } }
        VerticalLayout { alignment: center; Text { text: root.label; color: active ? Theme.accent-text : Theme.text2; font-size: 13px; font-weight: active ? 600 : 500; } }
    }
}

// A General-section row: icon + label (+ optional description) + a trailing control slot.
component SRow inherits HorizontalLayout {
    in property <string> icon;
    in property <string> label;
    in property <string> desc;
    padding-left: 15px;
    padding-right: 15px;
    padding-top: 13px;
    padding-bottom: 13px;
    spacing: 12px;
    VerticalLayout { alignment: center; StrokeIcon { width: 16px; height: 16px; tint: Theme.text2; commands: root.icon; } }
    VerticalLayout {
        horizontal-stretch: 1;
        alignment: center;
        spacing: 4px;
        Text { text: root.label; color: Theme.text; font-size: 13px; font-weight: 600; }
        if root.desc != "" : Text { text: root.desc; color: Theme.text3; font-size: 11.5px; }
    }
    @children
}

component InsetDiv inherits HorizontalLayout {
    padding-left: 15px;
    padding-right: 15px;
    Rectangle { height: 1px; background: Theme.stroke; }
}

// Settings — two-column modal (DESIGN-SPEC §Settings); shows the General section.
export component Settings inherits Rectangle {
    width: 720px;
    border-radius: 9px;
    background: Theme.bg;
    border-width: 1px;
    border-color: Theme.stroke;
    drop-shadow-blur: 36px;
    drop-shadow-color: #00000024;
    drop-shadow-offset-y: 12px;
    clip: true;

    VerticalLayout {
        Rectangle {
            height: 36px;
            background: Theme.bg2;
            HorizontalLayout {
                padding-left: 10px;
                spacing: 8px;
                VerticalLayout { alignment: center; Rectangle { width: 16px; height: 16px; border-radius: 4px; background: @linear-gradient(160deg, #117c44 0%, #0c5e32 100%);
                    StrokeIcon { width: 11px; height: 11px; tint: #ffffff; sw: 2px; commands: "M2.6 9 L13 9 L13 18 L2.6 18 Z M12.8 7.6 C13.6 4.2 17 2.9 19.6 4.8 M20.7 3.1 L21.1 5.8 L18.4 5.9"; } } }
                Text { text: "screen-hop — Settings"; color: Theme.text2; font-size: 11.5px; font-weight: 600; vertical-alignment: center; }
            }
        }

        HorizontalLayout {
            min-height: 430px;
            Rectangle {
                width: 164px;
                background: Theme.bg;
                VerticalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    padding-top: 12px;
                    spacing: 2px;
                    alignment: start;
                    NavItem { label: "General"; icon: Ico.gear; active: true; }
                    NavItem { label: "Paired peers"; icon: Ico.link; }
                    NavItem { label: "Manual hosts"; icon: Ico.net; }
                    NavItem { label: "Switching"; icon: Ico.refresh; }
                    NavItem { label: "About"; icon: Ico.info; }
                }
            }
            Rectangle { width: 1px; background: Theme.stroke; }
            Rectangle {
                horizontal-stretch: 1;
                background: Theme.bg;
                VerticalLayout {
                    padding-left: 20px;
                    padding-right: 20px;
                    padding-top: 16px;
                    padding-bottom: 16px;
                    spacing: 0px;
                    alignment: start;

                    Text { text: "General"; color: Theme.text; font-size: 16px; font-weight: 600; }
                    Rectangle { height: 12px; }
                    Rectangle {
                        border-radius: 9px;
                        background: Theme.layer;
                        border-width: 1px;
                        border-color: Theme.stroke;
                        clip: true;
                        VerticalLayout {
                            SRow {
                                icon: Ico.power;
                                label: "Start with Windows";
                                desc: "Launch to the system tray on sign-in";
                                VerticalLayout { alignment: center; Toggle { on: true; } }
                            }
                            InsetDiv { }
                            SRow {
                                icon: Ico.sun;
                                label: "Theme";
                                desc: "";
                                VerticalLayout { alignment: center; Seg3 { active: 1; } }
                            }
                            InsetDiv { }
                            SRow {
                                icon: Ico.keyboard;
                                label: "Global hotkeys";
                                desc: "Ctrl+Alt+1…4 apply presets from anywhere";
                                VerticalLayout { alignment: center; Toggle { on: true; } }
                            }
                        }
                    }
                }
            }
        }
    }
}
