import { Theme } from "theme.slint";
import { StrokeIcon, InfoGlyph } from "icons.slint";

// SVG path data for the dialog icons (24×24 viewbox).
export global Glyph {
    out property <string> alert: "M12 4 L22 19.5 L2 19.5 Z M12 10 L12 14.2";
    out property <string> close: "M6 6 L18 18 M18 6 L6 18";
    out property <string> check: "M5 12.5 L9.5 17 L19 7";
    out property <string> power: "M12 3.5 L12 10.5 M7.4 7.3 C4.7 9.6 4.7 15 8.6 17.4 C12.6 19.9 17.6 17.8 18 12.6 C18.2 10.2 17 8.2 16.2 7.4";
    out property <string> chevr: "M9 5 L16 12 L9 19";
}

// Footer button. kind: 0 = secondary, 1 = accent, 2 = danger.
component DBtn inherits Rectangle {
    in property <string> label;
    in property <int> kind;
    in property <length> h: 32px;
    callback clicked;
    height: h;
    width: t.preferred-width + 32px;
    border-radius: 6px;
    background: kind == 1 ? Theme.accent : kind == 2 ? Theme.danger : Theme.subtle;
    border-width: kind == 0 ? 1px : 0px;
    border-color: Theme.ctl-stroke;
    ta := TouchArea { clicked => { root.clicked(); } }
    t := Text {
        text: root.label;
        color: kind == 0 ? Theme.text : #ffffff;
        font-size: 13px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

// 38px round header badge with a stroked glyph.
component Badge inherits Rectangle {
    in property <color> bg;
    in property <color> fg;
    in property <string> icon;
    width: 38px;
    height: 38px;
    border-radius: 19px;
    background: bg;
    StrokeIcon { width: 19px; height: 19px; tint: fg; commands: root.icon; }
}

component DialogCard inherits Rectangle {
    in property <int> dwidth: 430;
    width: dwidth * 1px;
    border-radius: 9px;
    background: Theme.layer;
    border-width: 1px;
    border-color: Theme.stroke;
    drop-shadow-blur: 44px;
    drop-shadow-color: #0000002e;
    drop-shadow-offset-y: 16px;
}

// Monospace breadcrumb pill (DDC menu path).
component Crumb inherits Rectangle {
    in property <string> label <=> t.text;
    height: 22px;
    width: t.preferred-width + 16px;
    border-radius: 5px;
    background: Theme.subtle;
    border-width: 1px;
    border-color: Theme.stroke;
    t := Text { color: Theme.text; font-size: 12.5px; font-family: Theme.font-mono; horizontal-alignment: center; vertical-alignment: center; }
}

// One status row in the partial-failure dialog (top divider unless first).
component PartialRow inherits VerticalLayout {
    in property <string> label;
    in property <bool> ok;
    in property <bool> first;
    if !first : Rectangle { height: 1px; background: Theme.stroke; }
    HorizontalLayout {
        padding-top: 10px;
        padding-bottom: 10px;
        spacing: 11px;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 24px; height: 24px; border-radius: 12px;
                background: ok ? Theme.ok-bg : Theme.danger-bg;
                StrokeIcon { width: 13px; height: 13px; tint: ok ? Theme.accent-text : Theme.danger; sw: 2.1px; commands: ok ? Glyph.check : Glyph.close; }
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 1px;
            Text { text: root.label; color: Theme.text; font-size: 13px; font-weight: 600; }
            Text { text: ok ? "Switched" : "DDC/CI timeout"; color: ok ? Theme.accent-text : Theme.danger-text; font-size: 11px; }
        }
        if !ok : VerticalLayout { alignment: center; DBtn { label: "Retry"; kind: 0; h: 28px; } }
    }
}

export component BlindDialog inherits DialogCard {
    VerticalLayout {
        HorizontalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 20px; padding-bottom: 6px; spacing: 14px;
            Badge { bg: Theme.danger-bg; fg: Theme.danger; icon: Glyph.alert; }
            VerticalLayout { alignment: center; Text { text: "This PC will go blind"; color: Theme.text; font-size: 16px; font-weight: 600; } }
        }
        VerticalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 6px; spacing: 11px;
            Text { text: "Sending Right 27\" to Gaming leaves Work (this PC) with no display. You won't see this screen after the switch."; color: Theme.text2; font-size: 12.5px; wrap: word-wrap; }
            Rectangle {
                border-radius: 7px; background: Theme.warn-bg; border-width: 1px; border-color: Theme.warn-stroke;
                HorizontalLayout {
                    padding-left: 11px; padding-right: 11px; padding-top: 9px; padding-bottom: 9px; spacing: 9px;
                    VerticalLayout { StrokeIcon { width: 15px; height: 15px; tint: Theme.warn-accent; commands: Glyph.alert; } }
                    Text { text: "Keep at least one monitor on Work, or have another PC ready to switch it back."; color: Theme.warn-text; font-size: 12px; wrap: word-wrap; }
                }
            }
        }
        HorizontalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 18px; padding-bottom: 20px; spacing: 9px;
            Rectangle { horizontal-stretch: 1; }
            DBtn { label: "Cancel"; kind: 0; }
            DBtn { label: "Switch and go blind"; kind: 2; }
        }
    }
}

export component StrandedDialog inherits DialogCard {
    VerticalLayout {
        HorizontalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 20px; padding-bottom: 6px; spacing: 14px;
            Badge { bg: Theme.warn-bg; fg: Theme.warn-accent; icon: Glyph.alert; }
            VerticalLayout { alignment: center; Text { text: "Center 32\" is stranded"; color: Theme.text; font-size: 16px; font-weight: 600; } }
        }
        VerticalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 6px; spacing: 11px;
            Text { text: "It's driven by Home-lab, which is offline or asleep. Software can't pull a monitor away from an unreachable PC."; color: Theme.text2; font-size: 12.5px; wrap: word-wrap; }
            Rectangle {
                border-radius: 7px; background: Theme.bg2;
                HorizontalLayout {
                    padding: 11px; spacing: 9px;
                    VerticalLayout { StrokeIcon { width: 16px; height: 16px; tint: Theme.text2; commands: Glyph.power; } }
                    Text { text: "Press the monitor's Input / Source button on the bezel and choose this PC's connector (HDMI-2)."; color: Theme.text2; font-size: 12px; wrap: word-wrap; }
                }
            }
        }
        HorizontalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 18px; padding-bottom: 20px; spacing: 9px;
            Rectangle { horizontal-stretch: 1; }
            DBtn { label: "Retry detection"; kind: 0; }
            DBtn { label: "Got it"; kind: 1; }
        }
    }
}

export component DdcDialog inherits DialogCard {
    VerticalLayout {
        HorizontalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 20px; padding-bottom: 6px; spacing: 14px;
            Badge { bg: Theme.danger-bg; fg: Theme.danger; icon: Glyph.close; }
            VerticalLayout { alignment: center; Text { text: "Right 27\" isn't responding"; color: Theme.text; font-size: 16px; font-weight: 600; } }
        }
        VerticalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 6px; spacing: 12px;
            Text { text: "This monitor ignored DDC/CI commands. It's usually off in the on-screen menu."; color: Theme.text2; font-size: 12.5px; wrap: word-wrap; }
            Rectangle {
                border-radius: 8px; background: Theme.layer2; border-width: 1px; border-color: Theme.stroke;
                VerticalLayout {
                    padding-left: 14px; padding-right: 14px; padding-top: 12px; padding-bottom: 12px; spacing: 8px;
                    Text { text: "ENABLE IN THE MONITOR MENU"; color: Theme.text3; font-size: 10.5px; font-weight: 700; letter-spacing: 0.4px; }
                    HorizontalLayout {
                        spacing: 8px; alignment: start;
                        Crumb { label: "Menu"; }
                        VerticalLayout { alignment: center; StrokeIcon { width: 13px; height: 13px; tint: Theme.text3; commands: Glyph.chevr; } }
                        Crumb { label: "Others"; }
                        VerticalLayout { alignment: center; StrokeIcon { width: 13px; height: 13px; tint: Theme.text3; commands: Glyph.chevr; } }
                        Crumb { label: "DDC/CI"; }
                        VerticalLayout { alignment: center; StrokeIcon { width: 13px; height: 13px; tint: Theme.text3; commands: Glyph.chevr; } }
                        Rectangle {
                            height: 22px; width: onp.preferred-width; border-radius: 5px;
                            background: Theme.accent-soft; border-width: 1px; border-color: Theme.accent-soft-stroke;
                            onp := HorizontalLayout {
                                padding-left: 8px; padding-right: 8px;
                                Text { text: "On"; color: Theme.accent-text; font-size: 12.5px; font-weight: 600; font-family: Theme.font-mono; vertical-alignment: center; }
                            }
                        }
                    }
                }
            }
        }
        HorizontalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 16px; padding-bottom: 20px; spacing: 9px;
            Rectangle { horizontal-stretch: 1; }
            DBtn { label: "Skip this monitor"; kind: 0; }
            DBtn { label: "Retry"; kind: 1; }
        }
    }
}

export component PartialDialog inherits DialogCard {
    dwidth: 440;
    VerticalLayout {
        HorizontalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 20px; padding-bottom: 6px; spacing: 14px;
            Badge { bg: Theme.warn-bg; fg: Theme.warn-accent; icon: Glyph.alert; }
            VerticalLayout {
                alignment: center;
                spacing: 2px;
                Text { text: "Applied \"Trading\" — 2 of 3 switched"; color: Theme.text; font-size: 16px; font-weight: 600; }
                Text { text: "One monitor didn't respond. Retry it below."; color: Theme.text2; font-size: 12px; }
            }
        }
        VerticalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 8px;
            PartialRow { label: "Center 32\" → Gaming"; ok: true; first: true; }
            PartialRow { label: "Left 27\" → Work"; ok: true; }
            PartialRow { label: "Right 27\" → Work"; ok: false; }
        }
        HorizontalLayout {
            padding-left: 22px; padding-right: 22px; padding-top: 14px; padding-bottom: 18px; spacing: 8px;
            VerticalLayout { alignment: center; InfoGlyph { tint: Theme.text3; } }
            VerticalLayout { alignment: center; Text { text: "Presets are best-effort, not all-or-nothing."; color: Theme.text3; font-size: 11px; } }
            Rectangle { horizontal-stretch: 1; }
            DBtn { label: "Done"; kind: 1; }
        }
    }
}
