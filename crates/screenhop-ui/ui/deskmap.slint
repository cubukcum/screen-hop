import { Theme } from "theme.slint";
import { StrokeIcon, InfoGlyph } from "icons.slint";

// A patchbay cable: a faint 9px casing + a bright 3.2px core along `path`, with end dots.
component Cable inherits Rectangle {
    in property <string> path;
    in property <color> accent;
    in property <length> x1;
    in property <length> y1;
    in property <length> x2;
    in property <length> y2;
    Path { width: 660px; height: 312px; viewbox-width: 660; viewbox-height: 312; commands: root.path; stroke: root.accent.with-alpha(0.16); stroke-width: 9px; fill: transparent; }
    Path { width: 660px; height: 312px; viewbox-width: 660; viewbox-height: 312; commands: root.path; stroke: root.accent; stroke-width: 3.2px; fill: transparent; }
    Rectangle { x: root.x1 - 4.5px; y: root.y1 - 4.5px; width: 9px; height: 9px; border-radius: 4.5px; background: root.accent; }
    Rectangle { x: root.x2 - 4.5px; y: root.y2 - 4.5px; width: 9px; height: 9px; border-radius: 4.5px; background: root.accent; }
}

component PcNode inherits Rectangle {
    in property <string> name;
    in property <string> count;
    in property <color> accent;
    in property <string> icon;
    in property <bool> thispc;
    width: 188px;
    height: 84px;
    border-radius: 10px;
    background: Theme.layer;
    border-width: 1px;
    border-color: Theme.stroke;
    clip: true;
    Rectangle { x: 0; y: 0; width: 4px; height: 84px; background: root.accent; }
    HorizontalLayout {
        padding-left: 15px;
        padding-right: 12px;
        spacing: 11px;
        VerticalLayout { alignment: center; Rectangle { width: 36px; height: 36px; border-radius: 9px; background: root.accent.with-alpha(0.13); StrokeIcon { width: 20px; height: 20px; tint: root.accent; commands: root.icon; } } }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            HorizontalLayout {
                spacing: 6px;
                alignment: start;
                Text { text: root.name; color: Theme.text; font-size: 14px; font-weight: 600; vertical-alignment: center; }
                if thispc : Rectangle {
                    height: 15px;
                    width: tp.preferred-width + 10px;
                    border-radius: 8px;
                    background: Theme.accent-soft;
                    border-width: 1px;
                    border-color: Theme.accent-soft-stroke;
                    tp := Text { text: "THIS PC"; color: Theme.accent-text; font-size: 9px; font-weight: 700; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
            Text { text: root.count; color: Theme.text3; font-size: 11px; }
        }
        VerticalLayout { alignment: center; Rectangle { width: 9px; height: 9px; border-radius: 5px; background: Theme.ok-dot; } }
    }
}

component MonTile inherits Rectangle {
    in property <string> name;
    in property <string> spec;
    in property <string> owner;
    in property <color> accent;
    width: 230px;
    height: 84px;
    border-radius: 10px;
    background: Theme.layer;
    border-width: 1px;
    border-color: Theme.stroke;
    clip: true;
    VerticalLayout {
        padding-left: 14px;
        padding-right: 14px;
        alignment: center;
        spacing: 7px;
        HorizontalLayout {
            spacing: 9px;
            VerticalLayout { alignment: center; Rectangle { width: 30px; height: 30px; border-radius: 7px; background: root.accent.with-alpha(0.13); StrokeIcon { width: 18px; height: 18px; tint: root.accent; commands: "M2.5 4 L21.5 4 L21.5 17 L2.5 17 Z M8.5 20.5 L15.5 20.5 M12 17 L12 20.3"; } } }
            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                spacing: 1px;
                Text { text: root.name; color: Theme.text; font-size: 13.5px; font-weight: 600; }
                Text { text: root.spec; color: Theme.text3; font-size: 10.5px; overflow: elide; }
            }
        }
        HorizontalLayout {
            alignment: start;
            Rectangle {
                height: 22px;
                width: op.preferred-width;
                border-radius: 13px;
                background: Theme.subtle;
                border-width: 1px;
                border-color: Theme.stroke;
                op := HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 6px;
                    VerticalLayout { alignment: center; Rectangle { width: 7px; height: 7px; border-radius: 4px; background: root.accent; } }
                    Text { text: root.owner; color: Theme.text; font-size: 11.5px; font-weight: 600; vertical-alignment: center; }
                }
            }
        }
    }
}

// Desk map / patchbay (DESIGN-SPEC §2): peers on the left, monitors on the right, cables between.
export component DeskMap inherits Rectangle {
    width: 720px;
    border-radius: 9px;
    background: Theme.bg;
    border-width: 1px;
    border-color: Theme.stroke;
    drop-shadow-blur: 48px;
    drop-shadow-color: #00000029;
    drop-shadow-offset-y: 16px;
    clip: true;

    VerticalLayout {
        Rectangle {
            height: 36px;
            background: Theme.bg2;
            HorizontalLayout {
                padding-left: 10px;
                spacing: 8px;
                VerticalLayout { alignment: center; Rectangle { width: 16px; height: 16px; border-radius: 4px; background: @linear-gradient(160deg, #117c44 0%, #0c5e32 100%);
                    StrokeIcon { width: 11px; height: 11px; tint: #ffffff; sw: 2px; commands: "M2.6 9 L13 9 L13 18 L2.6 18 Z M12.8 7.6 C13.6 4.2 17 2.9 19.6 4.8 M20.7 3.1 L21.1 5.8 L18.4 5.9"; } } }
                Text { text: "screen-hop — Desk map"; color: Theme.text2; font-size: 11.5px; font-weight: 600; vertical-alignment: center; }
            }
        }

        VerticalLayout {
            padding-left: 20px;
            padding-right: 20px;
            padding-top: 15px;
            padding-bottom: 18px;
            spacing: 0px;

            HorizontalLayout {
                VerticalLayout {
                    spacing: 1px;
                    Text { text: "Desk map"; color: Theme.text; font-size: 18px; font-weight: 600; }
                    Text { text: "Lines show who drives what. Click a monitor to re-route it."; color: Theme.text3; font-size: 12px; }
                }
                Rectangle { horizontal-stretch: 1; }
                VerticalLayout { alignment: center; Rectangle {
                    height: 26px;
                    width: ao.preferred-width;
                    border-radius: 14px;
                    background: Theme.accent-soft;
                    border-width: 1px;
                    border-color: Theme.accent-soft-stroke;
                    ao := HorizontalLayout {
                        padding-left: 11px; padding-right: 11px; spacing: 6px;
                        VerticalLayout { alignment: center; Rectangle { width: 7px; height: 7px; border-radius: 4px; background: Theme.ok-dot; } }
                        Text { text: "All online"; color: Theme.accent-text; font-size: 12px; font-weight: 600; vertical-alignment: center; }
                    }
                } }
            }

            Rectangle { height: 12px; }
            Rectangle {
                height: 14px;
                Text { x: 0; text: "PEERS"; color: Theme.text3; font-size: 10px; font-weight: 700; letter-spacing: 0.5px; }
                Text { x: 430px; text: "MONITORS"; color: Theme.text3; font-size: 10px; font-weight: 700; letter-spacing: 0.5px; }
            }
            Rectangle { height: 6px; }

            Rectangle {   // patchbay canvas
                height: 306px;
                Cable { path: "M188 48 C 300 48 318 48 430 48"; accent: Theme.pc-work; x1: 188px; y1: 48px; x2: 430px; y2: 48px; }
                Cable { path: "M188 156 C 300 156 318 156 430 156"; accent: Theme.pc-gaming; x1: 188px; y1: 156px; x2: 430px; y2: 156px; }
                Cable { path: "M188 48 C 322 48 300 264 430 264"; accent: Theme.pc-work; x1: 188px; y1: 48px; x2: 430px; y2: 264px; }

                PcNode { x: 0; y: 6px; name: "Work"; count: "2 monitors"; accent: Theme.pc-work; thispc: true; icon: "M6 3 L18 3 L18 21 L6 21 Z M9.5 17.5 L14.5 17.5"; }
                PcNode { x: 0; y: 114px; name: "Gaming"; count: "1 monitor"; accent: Theme.pc-gaming; icon: "M6 3 L18 3 L18 21 L6 21 Z M9.5 17.5 L14.5 17.5"; }
                PcNode { x: 0; y: 222px; name: "Home-lab"; count: "idle"; accent: Theme.pc-homelab; icon: "M3.5 5 L20.5 5 L20.5 10.5 L3.5 10.5 Z M3.5 13.5 L20.5 13.5 L20.5 19 L3.5 19 Z"; }

                MonTile { x: 430px; y: 6px; name: "Left 27\""; spec: "Dell U2723QE · DP-1 · 1440p"; owner: "Work"; accent: Theme.pc-work; }
                MonTile { x: 430px; y: 114px; name: "Center 32\""; spec: "LG 32UN880 · HDMI-2 · 4K"; owner: "Gaming"; accent: Theme.pc-gaming; }
                MonTile { x: 430px; y: 222px; name: "Right 27\""; spec: "Dell U2723QE · DP-2 · 1440p"; owner: "Work"; accent: Theme.pc-work; }
            }

            Rectangle { height: 6px; }
            HorizontalLayout {
                spacing: 8px;
                alignment: start;
                VerticalLayout { alignment: center; InfoGlyph { tint: Theme.text3; } }
                Text { text: "Hover a PC to highlight its cables · drag a cable end to another monitor to re-route."; color: Theme.text3; font-size: 11px; vertical-alignment: center; }
            }
        }
    }
}
