import { Theme } from "theme.slint";

export struct Peer {
    label: string,
    color: color,   // per-PC brand color (active segment fill)
}

export struct MonitorRow {
    name: string,
    spec: string,
    active: int,   // index into `peers` = the PC currently driving this monitor
}

export struct Preset {
    name: string,
    active: bool,
}

// Variant C — "inline segmented, one click, no expand" (the selected design): each monitor row
// carries a Work|Gam|Lab segmented control whose highlighted segment is the current owner.
export component TrayFlyout inherits Rectangle {
    in property <[MonitorRow]> monitors;
    in property <[Peer]> peers;
    in property <[Preset]> presets;
    in property <int> online-count: 3;
    callback toggle-theme();
    callback switch(int, int);    // (monitor-index, peer-index)
    callback apply-preset(int);

    width: 340px;
    border-radius: 11px;
    background: Theme.layer;
    border-width: 1px;
    border-color: Theme.stroke;
    drop-shadow-blur: 30px;
    drop-shadow-color: #00000022;
    drop-shadow-offset-y: 8px;

    VerticalLayout {
        // ---------------- header ----------------
        HorizontalLayout {
            padding: 14px;
            padding-bottom: 12px;
            spacing: 9px;

            Rectangle {   // logo (click toggles theme — dev affordance, no chrome)
                width: 26px;
                height: 26px;
                border-radius: 7px;
                background: @linear-gradient(160deg, #117c44 0%, #0c5e32 100%);
                TouchArea { clicked => { root.toggle-theme(); } }
                Rectangle {
                    width: 14px;
                    height: 10px;
                    border-radius: 2px;
                    border-width: 1.6px;
                    border-color: #ffffff;
                    background: transparent;
                }
            }

            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    Text { text: "screen-"; color: Theme.text; font-size: 15px; font-weight: 600; }
                    Text { text: "hop"; color: Theme.accent-text; font-size: 15px; font-weight: 600; }
                }
            }

            Rectangle { horizontal-stretch: 1; }

            Rectangle {   // "N online" status pill
                height: 23px;
                border-radius: 11px;
                background: Theme.accent-soft;
                HorizontalLayout {
                    padding-left: 9px;
                    padding-right: 9px;
                    spacing: 5px;
                    Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Theme.ok-dot; }
                    Text { text: "\{online-count} online"; color: Theme.accent-text; font-size: 11.5px; font-weight: 600; vertical-alignment: center; }
                }
            }
        }

        Rectangle { height: 1px; background: Theme.stroke; }

        // ---------------- monitor rows ----------------
        for m[mi] in monitors: Rectangle {
            VerticalLayout {
                HorizontalLayout {
                    padding-left: 14px;
                    padding-right: 12px;
                    padding-top: 11px;
                    padding-bottom: 11px;
                    spacing: 10px;

                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: 1px;
                        Text { text: m.name; color: Theme.text; font-size: 13.5px; font-weight: 600; overflow: elide; }
                        Text { text: m.spec; color: Theme.text3; font-size: 11px; overflow: elide; }
                    }

                    Rectangle {   // segmented control
                        height: 28px;
                        border-radius: 7px;
                        background: Theme.subtle;
                        border-width: 1px;
                        border-color: Theme.ctl-stroke;
                        HorizontalLayout {
                            padding: 2px;
                            spacing: 0px;
                            for p[pi] in peers: Rectangle {
                                width: 40px;
                                border-radius: 6px;
                                background: pi == m.active ? p.color : transparent;
                                TouchArea { clicked => { root.switch(mi, pi); } }
                                Text {
                                    text: p.label;
                                    color: pi == m.active ? #ffffff : Theme.text2;
                                    font-size: 12px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }
                Rectangle {   // inter-row divider (skip after the last row)
                    height: 1px;
                    background: mi < monitors.length - 1 ? Theme.stroke : transparent;
                }
            }
        }

        Rectangle { height: 1px; background: Theme.stroke; }

        // ---------------- presets ----------------
        HorizontalLayout {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 11px;
            padding-bottom: 13px;
            spacing: 7px;
            alignment: start;
            Text { text: "PRESETS"; color: Theme.text3; font-size: 10.5px; font-weight: 700; letter-spacing: 0.5px; vertical-alignment: center; }
            for p[pi] in presets: Rectangle {
                height: 28px;
                width: ptxt.preferred-width + 20px;
                border-radius: 8px;
                background: p.active ? Theme.accent-soft : Theme.layer;
                border-width: 1px;
                border-color: p.active ? Theme.accent-soft-stroke : Theme.ctl-stroke;
                TouchArea { clicked => { root.apply-preset(pi); } }
                ptxt := Text {
                    text: p.name;
                    color: p.active ? Theme.accent-text : Theme.text;
                    font-size: 12.5px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
    }
}
