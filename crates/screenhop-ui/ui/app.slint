import { Theme } from "theme.slint";
import { TrayFlyout } from "tray_flyout.slint";

export { Theme }
export { TrayFlyout }

// Preview window hosting the tray flyout with sample data. The real app will surface the
// TrayFlyout from a system-tray popover and feed it live mesh state.
export component AppWindow inherits Window {
    title: "screen-hop";
    background: Theme.bg;
    in-out property <bool> dark <=> Theme.dark;

    VerticalLayout {
        padding: 16px;
        alignment: start;
        TrayFlyout {
            online-count: 3;
            monitors: [
                { name: "Dell U2723QE", spec: "27\" · 4K · DisplayPort", owner: "Work PC", accent: Theme.pc-work },
                { name: "LG 27GP950-B", spec: "27\" · 4K · HDMI 2", owner: "Gaming PC", accent: Theme.pc-gaming },
                { name: "AOC 27P2DG5", spec: "27\" · 1440p · DisplayPort", owner: "Home-lab", accent: Theme.pc-homelab },
            ];
            presets: [
                { name: "All to Work", active: true },
                { name: "Trading", active: false },
                { name: "Couch", active: false },
                { name: "Pair", active: false },
            ];
            toggle-theme => { Theme.dark = !Theme.dark; }
        }
    }
}
